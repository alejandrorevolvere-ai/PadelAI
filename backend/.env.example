# ── PadelAI Tutor — Variables de entorno ──────────────────────────────────────
# Copia este archivo como .env y completa los valores
# cp .env.example .env

# ── Entorno ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production

# ── Base de datos ──────────────────────────────────────────────────────────
# Local (dev): sqlite+aiosqlite:///./padel_ai_dev.db
# Producción (Supabase): postgresql+asyncpg://postgres:PASS@db.X.supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite:///./padel_ai_dev.db

# ── Redis (opcional en local) ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Seguridad ──────────────────────────────────────────────────────────────
# Genera una con: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# Orígenes permitidos para CORS (frontend)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── LLM / IA (NVIDIA NIM) ────────────────────────────────────────────────
# 1. Regístrate gratis en https://build.nvidia.com/
# 2. Ve a cualquier modelo → Get API Key
# 3. Copia la key aquí
LLM_API_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=TU_CLAVE_DE_NVIDIA_NIM
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# ── Stripe (opcional, para pagos) ──────────────────────────────────────────
# 1. Regístrate gratis en https://dashboard.stripe.com/register
# 2. Developers → API Keys → copia sk_live_...
# 3. Products → crea un producto con precio → copia price_xxx
# 4. Webhooks → add endpoint → copia whsec_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICES={}

# ── Rate limiting (seguridad) ─────────────────────────────────────────────
AUTH_RATE_LIMIT=10
GENERAL_RATE_LIMIT=120
RATE_LIMIT_WINDOW=60
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
MAX_REQUEST_BODY_SIZE=1048576
